# Godot 4 .gitignore
.godot/
/build/
/android/
*.translation

# Exported binaries
export.cfg
*.tmp

# Packaged web build for itch.io upload
/*-web.zip

# WSL NTFS metadata + raw LPC export archives
*:Zone.Identifier
assets/sprites/lpc_src/*.zip

# Raw LPC split-export dump (regenerate from docs/lpc-recipes.md); game uses the imported copies
assets/sprites/lpc_src/
.wrangler/
